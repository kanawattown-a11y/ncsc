generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DATA_ENTRY
  CHECKPOINT
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  password  String
  role      Role       @default(CHECKPOINT)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lastLogin DateTime?  // Timestamp of last successful login
  lastActive DateTime? // Timestamp of last heartbeat/activity

  auditLogs        AuditLog[]
  messagesSent     ChatMessage[] @relation("MessageSender")
  messagesReceived ChatMessage[] @relation("MessageReceiver")
  editRequests     EditRequest[]
  approvedRequests EditRequest[] @relation("RequestApprover")

  notificationsSent     Notification[]            @relation("NotificationSender")
  notificationsReceived Notification[]            @relation("NotificationTarget")
  readReceipts          NotificationReadReceipt[]
}

model Person {
  id            String    @id @default(cuid())
  nationalId    String    @unique
  fullName      String
  motherName    String?
  civilRecord   String?   // القيد
  civilRegistry String?   // الأمانة
  placeOfBirth  String?
  dateOfBirth   DateTime?
  gender        String?
  address       String?
  job           String?
  maritalStatus String?
  bloodType     String?
  physicalMarks String?
  photoUrl      String?   // URL to image
  notes         String?   // Tactical Free Description
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete

  records       SecurityRecord[]
  documents     Document[]
}

enum DocumentType {
  IMAGE
  PDF
  OTHER
}

model Document {
  id        String       @id @default(cuid())
  personId  String
  name      String
  type      DocumentType @default(OTHER)
  fileKey   String       // The S3 object key (e.g., persons/123456789/doc1.pdf)
  mimeType  String?
  size      Int?         // Size in bytes
  createdAt DateTime     @default(now())

  person    Person       @relation(fields: [personId], references: [id])
}

enum RecordSource {
  INTERNAL
  EXTERNAL
}

enum RecordType {
  SECURITY    // أمنية
  CRIMINAL    // جنائية
  POLITICAL   // سياسية
  ECONOMIC    // اقتصادية
  COURT       // محاكم وقضايا
  TRAVEL_BAN  // منع سفر
  EXIT_BAN    // منع خروج
  WANTED      // مطلوب
  OTHER       // أخرى
}

model SecurityRecord {
  id        String       @id @default(cuid())
  personId  String
  type      String       // Changed from RecordType Enum to String for dynamic admin control
  reason    String
  source    RecordSource @default(INTERNAL)
  branch    String?      // New: Requesting Branch (e.g., السياسي, الجوية, الجنائية)
  severity  String?      // e.g. HIGH, MEDIUM, LOW (Can be custom names now)
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  person    Person       @relation(fields: [personId], references: [id])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "WARRANT_TYPES", "BRANCHES", "SEVERITIES"
  value     Json     // List of strings or objects
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   
  entity    String   
  entityId  String?
  details   String?  
  timestamp DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model EditRequest {
  id              String        @id @default(cuid())
  dataEntryId     String
  entity          String        
  entityId        String?
  proposedChanges String        
  status          RequestStatus @default(PENDING)
  adminId         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  dataEntry       User          @relation(fields: [dataEntryId], references: [id])
  admin           User?         @relation("RequestApprover", fields: [adminId], references: [id])
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String?  // Optional: if null -> GENERAL ROOM. if UUID -> PRIVATE MESSAGE
  content    String
  timestamp  DateTime @default(now())

  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  receiver   User?    @relation("MessageReceiver", fields: [receiverId], references: [id])
}

enum NotificationPriority {
  NORMAL
  URGENT
}

model Notification {
  id           String               @id @default(cuid())
  title        String
  content      String
  priority     NotificationPriority @default(NORMAL)
  senderId     String
  targetRole   Role?                // If set -> all users of role (broadcast)
  targetUserId String?              // If set -> only this user (direct)
  createdAt    DateTime             @default(now())

  sender       User                 @relation("NotificationSender", fields: [senderId], references: [id])
  targetUser   User?                @relation("NotificationTarget", fields: [targetUserId], references: [id])
  receipts     NotificationReadReceipt[]
}

model NotificationReadReceipt {
  id             String       @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime     @default(now())

  notification   Notification @relation(fields: [notificationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([notificationId, userId])
}
