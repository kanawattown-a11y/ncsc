# === Database (AWS RDS PostgreSQL) ===
# Example: postgresql://admin:StrongPassword!@database-1.cluster.aws.com:5432/ncsc
DATABASE_URL="YOUR_RDS_URL_HERE"

# === Security / Authentication ===
# Run `openssl rand -base64 32` to generate a powerful secret
NEXTAUTH_SECRET="YOUR_RANDOM_LONG_STRING"
NEXTAUTH_URL="https://your-lightsail-domain.gov"

# === AWS S3 Configurations (For Documents & Uploads) ===
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="YOUR_IAM_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="YOUR_IAM_SECRET_KEY"
AWS_S3_BUCKET_NAME="ncsc-secure-bucket"
